# Keep the C .Call wrapper optimized consistently with the pure-C baseline.
LIBDIR = rust/target/release
STATLIB = $(LIBDIR)/librcrustc.a
PKG_LIBS = -L$(LIBDIR) -lrcrustc -lpthread -lm -ldl

$(SHLIB): $(STATLIB)

wrapper.o: wrapper.c
	$(CC) $(ALL_CPPFLAGS) $(ALL_CFLAGS) -O3 -ftree-vectorize -c $< -o $@

$(STATLIB):
	mkdir -p .cargo
	export CARGO_HOME=$(CURDIR)/.cargo; \
	export PATH="$(PATH):$(HOME)/.cargo/bin"; \
	cargo build --release --manifest-path=rust/Cargo.toml --target-dir=rust/target

clean:
	rm -Rf $(SHLIB) $(OBJECTS) $(STATLIB) rust/target .cargo
